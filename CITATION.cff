    title: "autoresearch"
    authors:
      - family-names: "Karpathy"
        given-names: "Andrej"
    url: "https://github.com/karpathy/autoresearch"
    notes: "The original program.md lab-notebook + edit-train-run experiment loop."
  - type: software
    title: "agent-smith"
    authors:
